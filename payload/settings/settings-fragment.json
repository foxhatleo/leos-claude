{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.test)",
      "Read(**/.env.staging)",
      "Read(**/.envrc)",
      "Read(**/.netrc)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.npmrc)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.docker/config.json)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(**/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'python3 \"$HOME\"/.claude/hooks/bash-guard.py; ec=$?; [ \"$ec\" = 43 ] && exit 2; exit 0'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'python3 \"$HOME\"/.claude/hooks/format-on-edit.py; ec=$?; [ \"$ec\" = 44 ] && exit 2; exit 0'",
            "timeout": 45
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'python3 \"$HOME\"/.claude/council/bin/council.py hook; ec=$?; [ \"$ec\" = 42 ] && exit 2; exit 0'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
